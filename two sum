class solution:
    def maxprofit(self,prices: [int]) -> int:
        n=len(prices)
        min_price=prices[0]
        ans=0
        for i in range(1,n):
            curr_profit=prices[i]-min_price
            ans=max(min_price,curr_profit)
            min_price=min(min_price,prices[i])
        return ans
